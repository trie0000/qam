# QAM 設定ファイル雛形。これを qam.env にコピーして編集する（qam.env は gitignore）。
# 書式: KEY=VALUE （# 始まりと空行は無視、前後クォートは剥がす）
# 優先順位: コマンドライン引数 > プロセス環境変数 > このファイル

# データ保管先（UNC 共有等のファイルサーバ）。current/ history/ comments/ raw/ がこの下に作られる。
#   例: QAM_DATA_DIR=\\YOUR-SERVER\share\qualys-asset-management
QAM_DATA_DIR=

# ローカル HTTP サーバの待受ポート（既定 18090）。127.0.0.1 で listen するので管理者権限不要。
QAM_RELAY_PORT=18090

# 保存期間（日）。これを過ぎた日次スナップショット snapshots/*/<date> と raw/<date> を剪定する。
# 設定画面から変更可能（変更は qam.env のこの値へ永続化される）。
# 改廃履歴 history/ と作業履歴コメント comments/ は剪定対象外（恒久記録）。
QAM_RAW_RETENTION_DAYS=90

# 誤取込ガード: 前回比で資産件数がこの割合以上に急減したら確定前に確認する（既定 0.5 = 50%）。
QAM_SHRINK_GUARD_RATIO=0.5

# --- Phase 4（API 直叩き）で使用予定。現時点では未使用。秘密情報は環境変数/各自入力で扱う。 ---
# QAM_QUALYS_API_BASE=https://YOUR-POD.qualysapi.example.com
# QAM_QUALYS_USER=
