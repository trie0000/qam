# QAM 設定ファイル雛形。これを qam.env にコピーして編集する（qam.env は gitignore）。
# 書式: KEY=VALUE （# 始まりと空行は無視、前後クォートは剥がす）
# 優先順位: コマンドライン引数 > プロセス環境変数 > このファイル

# 旧: ローカルのデータ保管先。管理データは SharePoint へ移したので、通常は設定不要。
# 以前のデータを SharePoint へ移送する（設定→開発者）ときの読み取り元としてのみ使う。
QAM_DATA_DIR=

# ローカル HTTP サーバの待受ポート（既定 18090）。127.0.0.1 で listen するので管理者権限不要。
QAM_RELAY_PORT=18090

# 保存期間（日）。これを過ぎた日次スナップショット snapshots/*/<date> と raw/<date> を剪定する。
# 設定画面から変更可能（変更は qam.env のこの値へ永続化される）。
# 改廃履歴 history/ と作業履歴コメント comments/ は剪定対象外（恒久記録）。
QAM_RAW_RETENTION_DAYS=90

# 誤取込ガード: 前回比で資産件数がこの割合以上に急減したら確定前に確認する（既定 0.5 = 50%）。
QAM_SHRINK_GUARD_RATIO=0.5

# --- Qualys API ダウンロード（プロキシ経由）。既定値。設定画面から上書き可能。 ---
# 接続先 POD（契約により qualysapi.qualys.com / qg2 / qg3 / EU 等）。
QAM_QUALYS_API_BASE=https://YOUR-POD.qualysapi.example.com
# プロキシ URL（社内プロキシ経由でないと Qualys に到達できない環境向け）。
QAM_PROXY_URL=http://YOUR-PROXY:8080
# Qualys アカウント。パスワードは env に置かず設定画面で入力するのを推奨（置く場合は各自の責任で）。
QAM_QUALYS_USER=
# QAM_QUALYS_PASSWORD=    # 非推奨。通常は設定画面から入力する。

# --- 四半期検査（SCAN/MAP の四半期ごとの充足チェック）---
# 年度開始月（1-12・既定 4）。4 なら Q1=4-6 / Q2=7-9 / Q3=10-12 / Q4=1-3。1 で暦年四半期。
QAM_FISCAL_START_MONTH=4
# 検査対象にする AssetGroup タイトルの正規表現（大文字小文字は無視）。
# 既定は「英字2文字＋数字3〜4桁＋末尾D(任意)」。空なら既定を使う。
QAM_INSPECTION_AG_PATTERN=^[A-Z]{2}[0-9]{3,4}D?$

# --- 検査（スケジュール）登録の既定値。登録画面で変更できる。 ---
# SCAN / MAP それぞれに適用するオプションプロファイル名（空ならアカウント既定）。
QAM_SCAN_OPTION_PROFILE=
QAM_MAP_OPTION_PROFILE=
# 既定のスキャナー（Scanner Appliance）。既定 External。
QAM_SCANNER_APPLIANCE=External
# 既定のタイムゾーンコード（大文字）。既定 JP。
QAM_SCHEDULE_TIME_ZONE=JP
# 地域区分「ラベル=コード」のカンマ区切り。コードはドメイン名の末尾に付く（例 ext-2026-001.jp）。
# 空なら既定の6区分を使う。
QAM_REGIONS=日本=jp,北米=na,中南米=la,欧州・CIS・中東阿=eu,インド=in,中国・北東アジア=cn

# --- 管理データの保管先（SharePoint 固定）---
# 管理データは SharePoint のリストとライブラリに置く。ライブラリとリストは初回起動時に自動作成される。
# アプリは SharePoint のページ上で動く必要がある（サインイン情報を使うため）。
QAM_SP_SITE_URL=https://YOUR-TENANT.sharepoint.com/sites/YOUR-SITE
QAM_SP_LIBRARY=QamData
